{
 "title": "Nutrition Lookup",
 "uid": "ps-nutrition-lookup",
 "tags": [
  "prog-strength"
 ],
 "schemaVersion": 39,
 "refresh": "30s",
 "time": {
  "from": "now-6h",
  "to": "now"
 },
 "timezone": "browser",
 "panels": [
  {
   "id": 1,
   "type": "stat",
   "title": "Lookups (24h)",
   "description": "Total nutrition lookups served, all outcomes. Context for the rates to the right \u2014 at low volume, single failures swing percentages hard.",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 4,
    "w": 6,
    "x": 0,
    "y": 0
   },
   "targets": [
    {
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "sum(increase(api_nutrition_lookup_requests_total[24h]))",
     "refId": "A",
     "instant": true
    }
   ],
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ],
     "fields": "",
     "values": false
    },
    "textMode": "value",
    "colorMode": "value",
    "graphMode": "area"
   },
   "fieldConfig": {
    "defaults": {
     "decimals": 0
    },
    "overrides": []
   }
  },
  {
   "id": 2,
   "type": "stat",
   "title": "Cache hit rate (24h)",
   "description": "Share of cache reads answered by a fresh row (no external calls, sub-ms). Climbs as users repeat foods; the 7-day freshness TTL re-pulls naturally. WARNING below 60% once warmed, CRITICAL below 25% \u2014 a persistently cold cache means every lookup spends FatSecret quota.",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 4,
    "w": 6,
    "x": 6,
    "y": 0
   },
   "targets": [
    {
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "100 * sum(increase(api_nutrition_lookup_cache_events_total{event=\"hit\"}[24h])) / clamp_min((sum(increase(api_nutrition_lookup_cache_events_total{event=~\"hit|miss|stale|corrupt\"}[24h]))), 1)",
     "refId": "A",
     "instant": true
    }
   ],
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ],
     "fields": "",
     "values": false
    },
    "textMode": "value",
    "colorMode": "value",
    "graphMode": "area"
   },
   "fieldConfig": {
    "defaults": {
     "unit": "percent",
     "decimals": 1,
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "red",
        "value": null
       },
       {
        "color": "yellow",
        "value": 25
       },
       {
        "color": "green",
        "value": 60
       }
      ]
     }
    },
    "overrides": []
   }
  },
  {
   "id": 3,
   "type": "stat",
   "title": "Provider failure rate (24h)",
   "description": "External API calls (FatSecret + USDA) that errored. WARNING above 5% (transient flakiness, IP-allowlist drift), CRITICAL above 25% (quota exhausted, credentials broken, provider outage). The stale-cache fallback masks user impact, so watch this \u2014 not user complaints.",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 4,
    "w": 6,
    "x": 12,
    "y": 0
   },
   "targets": [
    {
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "100 * sum(increase(api_nutrition_lookup_provider_requests_total{result=\"error\"}[24h])) / clamp_min(sum(increase(api_nutrition_lookup_provider_requests_total[24h])), 1)",
     "refId": "A",
     "instant": true
    }
   ],
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ],
     "fields": "",
     "values": false
    },
    "textMode": "value",
    "colorMode": "value",
    "graphMode": "area"
   },
   "fieldConfig": {
    "defaults": {
     "unit": "percent",
     "decimals": 1,
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       },
       {
        "color": "yellow",
        "value": 5
       },
       {
        "color": "red",
        "value": 25
       }
      ]
     }
    },
    "overrides": []
   }
  },
  {
   "id": 4,
   "type": "stat",
   "title": "Lookup failure rate (24h)",
   "description": "Requests that returned 503 (unavailable = no providers configured, failed = all providers down with no cache). These are the cases where the agent falls back to estimating macros. WARNING above 1%, CRITICAL above 10%. `unavailable` after a deploy usually means the .env secret threading regressed (see api#25).",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 4,
    "w": 6,
    "x": 18,
    "y": 0
   },
   "targets": [
    {
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "100 * sum(increase(api_nutrition_lookup_requests_total{outcome=~\"unavailable|failed\"}[24h])) / clamp_min(sum(increase(api_nutrition_lookup_requests_total[24h])), 1)",
     "refId": "A",
     "instant": true
    }
   ],
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ],
     "fields": "",
     "values": false
    },
    "textMode": "value",
    "colorMode": "value",
    "graphMode": "area"
   },
   "fieldConfig": {
    "defaults": {
     "unit": "percent",
     "decimals": 1,
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       },
       {
        "color": "yellow",
        "value": 1
       },
       {
        "color": "red",
        "value": 10
       }
      ]
     }
    },
    "overrides": []
   }
  },
  {
   "id": 5,
   "type": "timeseries",
   "title": "Lookup outcomes",
   "description": "Request dispositions over time. Healthy steady state: mostly cache_hit + served. served_stale means providers are down but users are covered; unavailable/failed means users are getting LLM estimates instead of database macros.",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 0,
    "y": 4
   },
   "targets": [
    {
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "sum by (outcome) (rate(api_nutrition_lookup_requests_total[5m]))",
     "refId": "A",
     "legendFormat": "{{outcome}}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "custom": {
      "fillOpacity": 50,
      "stacking": {
       "mode": "normal",
       "group": "A"
      }
     },
     "unit": "reqps"
    },
    "overrides": []
   }
  },
  {
   "id": 6,
   "type": "timeseries",
   "title": "Cache reads",
   "description": "Cache read dispositions. miss = first sighting of a food; stale = freshness TTL (7d) expired, triggering a re-pull; corrupt/read_error should be flat zero \u2014 anything else means SQLite trouble.",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 12,
    "y": 4
   },
   "targets": [
    {
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "sum by (event) (rate(api_nutrition_lookup_cache_events_total[5m]))",
     "refId": "A",
     "legendFormat": "{{event}}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "custom": {
      "fillOpacity": 50,
      "stacking": {
       "mode": "normal",
       "group": "A"
      }
     },
     "unit": "reqps"
    },
    "overrides": []
   }
  },
  {
   "id": 7,
   "type": "timeseries",
   "title": "Provider calls by source and result",
   "description": "External API traffic split by provider and outcome. FatSecret errors with USDA still ok usually means the FatSecret IP allowlist or OAuth credentials; both erroring together suggests egress/network trouble on the host.",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 0,
    "y": 12
   },
   "targets": [
    {
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "sum by (source, result) (rate(api_nutrition_lookup_provider_requests_total[5m]))",
     "refId": "A",
     "legendFormat": "{{source}} {{result}}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "custom": {
      "fillOpacity": 25
     },
     "unit": "reqps"
    },
    "overrides": []
   }
  },
  {
   "id": 8,
   "type": "timeseries",
   "title": "Provider latency p95",
   "description": "95th-percentile external call latency per provider. Dashed lines: WARNING 2s, CRITICAL 5s \u2014 the http.Client timeout is 8s, and every slow provider call holds the agent's tool loop open. Sustained breach: consider raising max_results selectivity or checking provider status pages.",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 12,
    "y": 12
   },
   "targets": [
    {
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "histogram_quantile(0.95, sum by (source, le) (rate(api_nutrition_lookup_provider_duration_seconds_bucket[5m])))",
     "refId": "A",
     "legendFormat": "{{source}}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "custom": {
      "fillOpacity": 25,
      "thresholdsStyle": {
       "mode": "dashed"
      }
     },
     "unit": "s",
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       },
       {
        "color": "yellow",
        "value": 2
       },
       {
        "color": "red",
        "value": 5
       }
      ]
     }
    },
    "overrides": []
   }
  },
  {
   "id": 9,
   "type": "timeseries",
   "title": "Cache writes",
   "description": "Upserts into nutrition_lookup_cache (each also runs the 90-day eviction sweep). `error` should be flat zero \u2014 writes failing silently degrades every future lookup to full provider cost; correlate with disk space or SQLite lock contention if it moves.",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 0,
    "y": 20
   },
   "targets": [
    {
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "sum by (result) (rate(api_nutrition_lookup_cache_writes_total[5m]))",
     "refId": "A",
     "legendFormat": "{{result}}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "custom": {
      "fillOpacity": 25
     },
     "unit": "reqps"
    },
    "overrides": []
   }
  },
  {
   "id": 10,
   "type": "timeseries",
   "title": "Endpoint latency (p50 / p95 / p99)",
   "description": "Server-side latency for GET /nutrition/lookup, all outcomes. Cache hits should pin p50 near zero; the upper percentiles reflect provider round trips. Dashed lines: WARNING 2s, CRITICAL 5s.",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 12,
    "y": 20
   },
   "targets": [
    {
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "histogram_quantile(0.50, sum by (le) (rate(ps_http_request_duration_seconds_bucket{route=\"/nutrition/lookup\"}[5m])))",
     "refId": "A",
     "legendFormat": "p50"
    },
    {
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "histogram_quantile(0.95, sum by (le) (rate(ps_http_request_duration_seconds_bucket{route=\"/nutrition/lookup\"}[5m])))",
     "refId": "B",
     "legendFormat": "p95"
    },
    {
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "expr": "histogram_quantile(0.99, sum by (le) (rate(ps_http_request_duration_seconds_bucket{route=\"/nutrition/lookup\"}[5m])))",
     "refId": "C",
     "legendFormat": "p99"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "custom": {
      "fillOpacity": 25,
      "thresholdsStyle": {
       "mode": "dashed"
      }
     },
     "unit": "s",
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       },
       {
        "color": "yellow",
        "value": 2
       },
       {
        "color": "red",
        "value": 5
       }
      ]
     }
    },
    "overrides": []
   }
  }
 ]
}
