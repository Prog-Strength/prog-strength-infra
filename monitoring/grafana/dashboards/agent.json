    {
      "id": 7,
      "type": "timeseries",
      "title": "Chat turn rate (per second)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 27
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(http_requests_total{job=\"agent\", handler=\"/chat\"}[5m]))",
          "legendFormat": "/chat",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "description": "Per-second rate of POST /chat requests \u2014 live conversation throughput. Context for the latency and error panels beside it."
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Chat latency (p50 / p95)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 27
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"agent\", handler=\"/chat\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"agent\", handler=\"/chat\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "vector(3)",
          "legendFormat": "warning (3s)",
          "refId": "C"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "vector(8)",
          "legendFormat": "critical (8s)",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "warning (3s)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "yellow"
                }
              },
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [
                    10,
                    10
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "critical (8s)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              },
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [
                    10,
                    10
                  ]
                }
              }
            ]
          }
        ]
      },
      "description": "End-to-end /chat handler latency percentiles, measured server-side \u2014 what the user waits for on each turn. Dashed yellow / red lines mark the warning (3s) and critical (8s) thresholds."
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Errors per tier (turns ending in error)",
      "description": "Rate of turns whose completion_reason was 'error', broken down by tier so you can see if one model is failing disproportionately. For a low-traffic app the magnitude matters more than the ratio \u2014 dashed yellow / red lines mark the warning (1) and critical (3) thresholds.",
