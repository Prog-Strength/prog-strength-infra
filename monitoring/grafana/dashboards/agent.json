    {
      "id": 13,
      "type": "timeseries",
      "title": "Tool errors / sec (by tool)",
      "description": "Rate of tool calls whose MCP response signaled an error. A tool error doesn't necessarily fail the chat turn \u2014 the agent often retries or works around it \u2014 but any sustained non-zero rate usually points at a broken tool or a model calling it wrong, so the dashed warning line sits just above zero.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 52
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (tool_name) (rate(agent_tool_calls_total{outcome=\"error\"}[5m]))",
          "legendFormat": "{{tool_name}}",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "vector(0.01)",
          "legendFormat": "warning (>0)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "warning (>0)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "yellow"
                }
              },
              {
                "id": "custom.lineStyle",
