{
  "title": "Agent Observability",
  "uid": "ps-agent",
  "tags": ["prog-strength"],
  "schemaVersion": 39,
  "timezone": "browser",
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total turns (24h)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum(increase(agent_turns_total[24h]))",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {"unit": "short", "decimals": 0, "color": {"mode": "fixed", "fixedColor": "blue"}},
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Tokens in (24h)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum(increase(agent_tokens_total{direction=\"input\"}[24h]))",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {"unit": "short", "decimals": 0, "color": {"mode": "fixed", "fixedColor": "purple"}},
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Tokens out (24h)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum(increase(agent_tokens_total{direction=\"output\"}[24h]))",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {"unit": "short", "decimals": 0, "color": {"mode": "fixed", "fixedColor": "orange"}},
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Cache reads (24h)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum(increase(agent_tokens_total{direction=\"cache_read\"}[24h]))",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {"unit": "short", "decimals": 0, "color": {"mode": "fixed", "fixedColor": "green"}},
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Routing decisions over time (by tier)",
      "description": "Rate of Haiku-tier vs Sonnet-tier classifications coming out of the model router. Stacks the two so you can read both the absolute rate and the split.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (tier) (rate(agent_routing_decisions_total[5m]))",
          "legendFormat": "{{tier}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"stacking": {"mode": "normal", "group": "A"}, "fillOpacity": 50}
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "piechart",
      "title": "Tier split (24h)",
      "description": "Share of turns routed to each tier in the last 24 hours. A skew toward 'complex' means routing is paying for Sonnet often — worth a look at the router's classifications if it feels wrong.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (tier) (increase(agent_routing_decisions_total[24h]))",
          "legendFormat": "{{tier}}",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "pieType": "donut",
        "tooltip": {"mode": "single"},
        "legend": {"displayMode": "list", "placement": "right", "showLegend": true, "values": ["value", "percent"]}
      },
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Chat turn rate (per second)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum(rate(http_requests_total{job=\"agent\", handler=\"/chat\"}[5m]))",
          "legendFormat": "/chat",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps"},
        "overrides": []
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Chat latency (p50 / p95)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"agent\", handler=\"/chat\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"agent\", handler=\"/chat\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "s"},
        "overrides": []
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Errors per tier (turns ending in error)",
      "description": "Rate of turns whose completion_reason was 'error'. Broken down by tier so you can see if one model is failing disproportionately.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 20},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (tier) (rate(agent_turns_total{completion_reason=\"error\"}[5m]))",
          "legendFormat": "{{tier}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps"},
        "overrides": []
      }
    }
  ]
}
