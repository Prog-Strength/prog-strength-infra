# Non-secret app config consumed by deploy/agent.sh when it assembles .env.
# CORS_ALLOWED_ORIGINS is a comma-separated list of public frontend origins,
# not a secret — committed here so it is version-controlled and can't silently
# go missing. An empty value disables the agent's CORS middleware (the
# `if config.cors_allowed_origins:` guard in server.py) and 405s the browser's
# OPTIONS preflight. The agent container reads it via compose
# (CORS_ALLOWED_ORIGINS=${CORS_ALLOWED_ORIGINS:-} in docker-compose.yml).
CORS_ALLOWED_ORIGINS=https://progstrength.fitness
