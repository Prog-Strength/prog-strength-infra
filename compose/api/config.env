# Non-secret app config consumed by deploy/api.sh when it assembles .env.
# Bucket names mirror the defaults in the root variables.tf (the backup /
# tcx_storage / avatar_storage objects) — that is the canonical source; keep
# these in sync. They are explicit constants by design so they can be
# referenced cross-repo without a Terraform output round-trip.
# LITESTREAM_REPLICA_REGION matches api.sh's AWS_REGION; it is intentionally
# not in api.sh's required-key gate (a wrong region degrades replication, it
# doesn't take prod down).
LITESTREAM_REPLICA_BUCKET=prog-strength-database-backups
LITESTREAM_REPLICA_REGION=us-east-2
TCX_BUCKET_NAME=prog-strength-tcx-uploads
AVATAR_BUCKET_NAME=prog-strength-avatars
GOOGLE_CLIENT_ID=741441200010-ro8c8qj99qdnqgc5q8m12ondghe5efn5.apps.googleusercontent.com
FATSECRET_CLIENT_ID=9e38ec3ebde54ff3943bfff68142b7dd
# WHOOP recovery integration (optional). Deployment-bound, non-secret client id;
# the owner fills this at rollout. Empty leaves the Whoop integration disabled.
WHOOP_CLIENT_ID=
