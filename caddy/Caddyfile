# HTTPS reverse proxy for prog-strength services.
#
# Caddy obtains a Let's Encrypt cert for each vhost on first request, auto-
# renews it, and redirects HTTP -> HTTPS. The upstream services (`api`,
# `mcp`) are only reachable on the shared docker network `prog-strength`
# — Caddy is the only container with public ports.
#
# Adding the apex (progstrength.fitness) here later, once the frontend
# lands on EC2, is a one-block addition. If the frontend goes on Vercel
# or similar, point the apex DNS record there instead and leave this file
# alone.

api.progstrength.fitness {
	reverse_proxy api:8080
}

mcp.progstrength.fitness {
	reverse_proxy mcp:8000
}
