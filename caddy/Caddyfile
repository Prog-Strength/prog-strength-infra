# HTTPS reverse proxy for the API.
#
# Caddy obtains a Let's Encrypt cert for api.progstrength.fitness on first
# request, auto-renews it, and redirects HTTP -> HTTPS. The api service
# is only reachable on the docker-compose internal network — Caddy is the
# only container with public ports.
#
# Adding the apex (progstrength.fitness) here later, once the frontend
# lands on EC2, is a one-block addition. If the frontend goes on Vercel
# or similar, point the apex DNS record there instead and leave this file
# alone.
#
# The mcp.progstrength.fitness block will land here once the MCP server
# ships — it can share Caddy with the api since both are reached on the
# docker-compose internal network of their respective deployments.

api.progstrength.fitness {
	reverse_proxy api:8080
}
